# Dynamic theme colors (omarchy managed)
config-file = ?"~/.config/omarchy/current/theme/ghostty.conf"

# Font
# Ghostty 1.3.0+ natively fixes Brahmic/Bengali script rendering.
# Adding Noto Sans Bengali as fallback ensures proper conjunct and
# vowel sign shaping without needing symbol_map workarounds like Kitty.
font-family = "JetBrainsMono Nerd Font"
font-family = "Noto Sans Bengali"
font-style = Regular
font-size = 12

# Window
window-theme = ghostty
window-padding-x = 2
window-padding-y = 2
window-decoration = false
confirm-close-surface = false
resize-overlay = never
gtk-toolbar-style = flat

# Shell (matches kitty: shell zsh -c "~/.bin/init; exec zsh")
command = /bin/zsh -c "~/.bin/init; exec zsh"

# Cursor
cursor-style = block
cursor-style-blink = false
shell-integration-features = no-cursor,ssh-env

# Bell
bell-features = no-audio,no-system

# Tab bar
gtk-tabs-location = hidden

# Scrolling
mouse-scroll-multiplier = 0.95

# Fix general slowness on Hyprland
async-backend = epoll

# Keyboard bindings
# Copy/paste
keybind = ctrl+shift+c=copy_to_clipboard
keybind = ctrl+shift+v=paste_from_clipboard
keybind = shift+insert=paste_from_clipboard
keybind = control+insert=copy_to_clipboard

# Disable unused kitty_mod bindings
keybind = ctrl+shift+t=unbind
keybind = ctrl+shift+q=unbind
keybind = ctrl+shift+w=unbind

# Sessionizer launchers: Ghostty doesn't support per-keybind commands like Kitty's
# `launch --type=window`. Use Hyprland bindings or a wrapper script instead.

# Pass Ctrl+number to tmux for browser-like tab switching
keybind = ctrl+one=text:\x1b[49;5u
keybind = ctrl+two=text:\x1b[50;5u
keybind = ctrl+three=text:\x1b[51;5u
keybind = ctrl+four=text:\x1b[52;5u
keybind = ctrl+five=text:\x1b[53;5u
keybind = ctrl+six=text:\x1b[54;5u
keybind = ctrl+seven=text:\x1b[55;5u
keybind = ctrl+eight=text:\x1b[56;5u
keybind = ctrl+nine=text:\x1b[57;5u

# Pass Shift+Left/Right to tmux
keybind = shift+left=text:\x1b[1;2D
keybind = shift+right=text:\x1b[1;2C

# Split resize
keybind = super+control+shift+alt+arrow_down=resize_split:down,100
keybind = super+control+shift+alt+arrow_up=resize_split:up,100
keybind = super+control+shift+alt+arrow_left=resize_split:left,100
keybind = super+control+shift+alt+arrow_right=resize_split:right,100
